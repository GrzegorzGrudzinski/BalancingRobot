{
    "configurations": [
        // Linux config
        {
            "name": "Linux",
            "includePath":
            [
                "${workspaceRoot}/code",
                "${workspaceRoot}/code/Core/Inc",
                "${workspaceRoot}/code/Drivers/STM32F4xx_HAL_Driver/Inc",
                "${workspaceRoot}/code/Drivers/CMSIS/Include",
                "${workspaceRoot}/code/Drivers/CMSIS/Device/ST/STM32F4xx/Include",
                "${workspaceRoot}/code/USB_HOST/App",
                "${workspaceRoot}/code/USB_HOST/Target",
                "/lib/gcc/arm-none-eabi/15.2.0/include",
                "/lib/gcc/arm-none-eabi/15.2.0/include-fixed",
                "/usr/arm-none-eabi/include",
                "/usr/arm-none-eabi/include/c++/15.2.0",
                "/usr/arm-none-eabi/include/machine",
                "/usr/arm-none-eabi/include/newlib-nano",
                "/usr/arm-none-eabi/include/sys"
